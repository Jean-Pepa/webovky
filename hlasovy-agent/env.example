# Zkopíruj tento soubor na ".env" a vyplň hodnoty.
#   PowerShell:  Copy-Item env.example .env

# --- Povinné ---
# API klíč z https://platform.claude.com/  (Settings -> API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# --- Volitelné (mají rozumné výchozí hodnoty) ---

# Model agenta. Pro běžnou práci sonnet (rychlý + levný),
# pro nejtěžší úlohy claude-opus-4-8.
AGENT_MODEL=claude-sonnet-4-6

# Složka projektu, na kterém má agent pracovat (kořen, kam smí sahat).
# Pokud necháš prázdné, použije se aktuální složka, ze které agenta spustíš.
PROJECT_DIR=C:\Users\tvoje-jmeno\projekty\muj-projekt

# Velikost Whisper modelu: tiny | base | small | medium | large-v3
# small = rychlý start na CPU; medium/large-v3 = přesnější (ideálně s GPU).
WHISPER_MODEL=small

# Zařízení pro Whisper: auto | cpu | cuda  (cuda = NVIDIA GPU)
WHISPER_DEVICE=auto

# Výpočetní typ: int8 (CPU) | float16 (GPU) | float32
WHISPER_COMPUTE=int8

# Jazyk přepisu řeči
STT_LANGUAGE=cs

# Kam ukládat logy konverzací
LOG_DIR=logs
