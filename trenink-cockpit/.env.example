# Zkopíruj do .env.local a doplň hodnoty ze Supabase (Project Settings → API).
# Bez těchto proměnných appka jede v localStorage režimu (data jen v prohlížeči).

# Veřejné (jdou i do prohlížeče) — appka čte/zapisuje deník:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Tajné (jen server / skripty) — Claude tím zapisuje aktivity z Garminu:
SUPABASE_SERVICE_ROLE_KEY=
