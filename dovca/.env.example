# Heslo do appky (společné pro partu). Když není nastaveno, platí "dovca".
DOVCA_PASSWORD=tajneheslo

# Sdílené úložiště (Upstash Redis nebo Vercel KV). Bez něj appka jede
# v demo režimu — data jen v prohlížeči (localStorage).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# nebo varianta z Vercel Storage:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
